# -- Database --
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/fuzebox_telemetry

# -- LLM --
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
EVALUATOR_MODEL=o3-mini
FALLBACK_MODEL=gpt-3.5-turbo

# -- CORS --
CORS_ORIGINS=http://localhost:5173,https://your-vercel-url.vercel.app

# -- Observability --
SENTRY_DSN=

# -- Rate Limiting --
RATE_LIMIT_RUN=10/minute
RATE_LIMIT_READ=60/minute

# -- Agent Pipeline --
MAX_ITERATIONS=10
AGENT_TIMEOUT_S=30
MAX_INPUT_LENGTH=5000
